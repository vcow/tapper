<?xml version="1.0"?>
<f:LayoutGroupListItemRenderer xmlns:fx="http://ns.adobe.com/mxml/2009" xmlns:f="library://ns.feathersui.com/mxml">
    <f:layout>
        <f:AnchorLayout/>
    </f:layout>

    <f:LayoutGroup backgroundSkin="{new Quad(120, 90, 0x909090)}"/>

    <f:Label text="{counter}" styleProvider="{StylesLibrary.counterLabelStyleProvider}">
        <f:layoutData>
            <f:AnchorLayoutData right="5" bottom="3"/>
        </f:layoutData>
    </f:Label>

    <fx:Script><![CDATA[
        import resources.StylesLibrary;

        import starling.display.Quad;

        [Bindable]
        public var counter:String;

        ]]></fx:Script>
</f:LayoutGroupListItemRenderer>
