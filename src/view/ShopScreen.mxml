<?xml version="1.0"?>
<f:LayoutGroup xmlns:fx="http://ns.adobe.com/mxml/2009" xmlns:f="library://ns.feathersui.com/mxml">
    <f:layout>
        <f:VerticalLayout gap="5" horizontalAlign="center"/>
    </f:layout>

    <f:LayoutGroup>
        <f:layout>
            <f:HorizontalLayout verticalAlign="middle" padding="1" gap="2"/>
        </f:layout>
        <f:layoutData>
            <f:VerticalLayoutData percentWidth="100"/>
        </f:layoutData>

        <f:Button styleProvider="{StylesLibrary.backButtonStyleProvider}" triggered="{dispatchEventWith(BACK)}"/>

        <f:Label text="{money}" styleProvider="{StylesLibrary.moneyLabelStyleProvider}">
            <f:layoutData>
                <f:HorizontalLayoutData percentWidth="100"/>
            </f:layoutData>
        </f:Label>

        <f:LayoutGroup width="50"/>
    </f:LayoutGroup>

    <fx:Script><![CDATA[
        import resources.StylesLibrary;

        public static const BACK:String = "back";

        [Bindable]
        public var money:Number = 0;
        ]]></fx:Script>
</f:LayoutGroup>
