<?xml version="1.0"?>
<f:LayoutGroup xmlns:fx="http://ns.adobe.com/mxml/2009" xmlns:f="library://ns.feathersui.com/mxml" xmlns:view="view.*"
               implements="view.IGameScreen" backgroundSkin="{new Quad(10, 10, 0xff0000)}">
    <f:layout>
        <f:AnchorLayout/>
    </f:layout>
    <f:layoutData>
        <f:AnchorLayoutData percentWidth="100" percentHeight="100"/>
    </f:layoutData>

    <f:LayoutGroup>
        <f:layout>
            <f:VerticalLayout gap="5" horizontalAlign="center"/>
        </f:layout>
        <f:layoutData>
            <f:AnchorLayoutData percentWidth="100" percentHeight="100"/>
        </f:layoutData>

        <f:LayoutGroup>
            <f:layout>
                <f:HorizontalLayout verticalAlign="middle" padding="1" gap="2"/>
            </f:layout>
            <f:layoutData>
                <f:VerticalLayoutData percentWidth="100"/>
            </f:layoutData>

            <f:Button styleProvider="{StylesLibrary.backButtonStyleProvider}"
                      triggered="{dispatchEventWith(GameScreen.BACK, true)}"/>

            <f:Label text="{_money}" styleProvider="{StylesLibrary.moneyLabelStyleProvider}">
                <f:layoutData>
                    <f:HorizontalLayoutData percentWidth="100"/>
                </f:layoutData>
            </f:Label>

            <f:Button styleProvider="{StylesLibrary.woodenShopButtonStyleNormalProvider}"
                      triggered="{dispatchEventWith(GameScreen.SHOP, true)}"/>
        </f:LayoutGroup>

        <f:LayoutGroup height="70">
            <f:layout>
                <f:AnchorLayout/>
            </f:layout>

            <f:Label text="{_levelDescription}" styleProvider="{StylesLibrary.levelDescriptionStyleProvider}">
                <f:layoutData>
                    <f:AnchorLayoutData verticalCenter="0"/>
                </f:layoutData>
            </f:Label>
        </f:LayoutGroup>

        <f:List styleProvider="{StylesLibrary.shopScrollerStyleProvider}" dataProvider="{_unitsList}"
                itemRendererType="view.UnitListItemRenderer" isSelectable="false">
            <f:layout>
                <f:TiledRowsLayout gap="2" padding="5" paddingTop="10"/>
            </f:layout>
            <f:layoutData>
                <f:VerticalLayoutData percentWidth="100" percentHeight="100"/>
            </f:layoutData>
        </f:List>
    </f:LayoutGroup>

    <view:ShopWidget id="sv">
        <view:layoutData>
            <f:AnchorLayoutData top="50" right="0"/>
        </view:layoutData>
    </view:ShopWidget>

    <fx:Script><![CDATA[
        import feathers.data.ListCollection;

        import resources.StylesLibrary;
        import resources.locale.LocaleManager;

        import starling.display.Quad;

        [Bindable]
        private var _money:Number = 0;

        [Bindable]
        private var _unitsList:ListCollection;

        [Bindable]
        private var _levelDescription:String;

        public function set money(value:Number):void
        {
            _money = value;
        }

        public function set unitsList(value:ListCollection):void
        {
            _unitsList = value;
        }

        public function set levelDescription(value:String):void
        {
            _levelDescription = value;
        }
        ]]></fx:Script>
</f:LayoutGroup>
