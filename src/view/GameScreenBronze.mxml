<?xml version="1.0"?>
<f:LayoutGroup xmlns:fx="http://ns.adobe.com/mxml/2009" xmlns:f="library://ns.feathersui.com/mxml" xmlns:view="view.*"
               backgroundSkin="{new Quad(10, 10, 0xff0000)}">
    <f:layout>
        <f:AnchorLayout/>
    </f:layout>
    <f:layoutData>
        <f:AnchorLayoutData percentWidth="100" percentHeight="100"/>
    </f:layoutData>

    <f:LayoutGroup>
        <f:layout>
            <f:VerticalLayout gap="5" horizontalAlign="center"/>
        </f:layout>
        <f:layoutData>
            <f:AnchorLayoutData percentWidth="100" percentHeight="100"/>
        </f:layoutData>

        <f:LayoutGroup>
            <f:layout>
                <f:HorizontalLayout verticalAlign="middle" padding="1" gap="2"/>
            </f:layout>
            <f:layoutData>
                <f:VerticalLayoutData percentWidth="100"/>
            </f:layoutData>

            <f:Button styleProvider="{StylesLibrary.backButtonStyleProvider}"
                      triggered="{dispatchEventWith(GameScreen.BACK, true)}"/>

            <f:Label text="{_mediator.money}" styleProvider="{StylesLibrary.moneyLabelStyleProvider}">
                <f:layoutData>
                    <f:HorizontalLayoutData percentWidth="100"/>
                </f:layoutData>
            </f:Label>

            <f:Button styleProvider="{StylesLibrary.woodenShopButtonStyleNormalProvider}"
                      triggered="{dispatchEventWith(GameScreen.SHOP, true)}"/>
        </f:LayoutGroup>

        <f:LayoutGroup height="70">
            <f:layout>
                <f:AnchorLayout/>
            </f:layout>

            <f:Label text="{_mediator.levelDescription}" styleProvider="{StylesLibrary.levelDescriptionStyleProvider}">
                <f:layoutData>
                    <f:AnchorLayoutData verticalCenter="0"/>
                </f:layoutData>
            </f:Label>
        </f:LayoutGroup>

        <f:List styleProvider="{StylesLibrary.shopScrollerStyleProvider}" dataProvider="{_mediator.unitsList}"
                itemRendererType="view.UnitListItemRenderer" isSelectable="false">
            <f:layout>
                <f:TiledRowsLayout gap="2" padding="5" paddingTop="10"/>
            </f:layout>
            <f:layoutData>
                <f:VerticalLayoutData percentWidth="100" percentHeight="100"/>
            </f:layoutData>
        </f:List>
    </f:LayoutGroup>

    <view:ShopWidget id="sv">
        <view:layoutData>
            <f:AnchorLayoutData top="50" right="0"/>
        </view:layoutData>
    </view:ShopWidget>

    <fx:Script><![CDATA[
        import app.AppFacade;

        import mediators.GameScreenMediator;

        import org.puremvc.as3.multicore.patterns.facade.Facade;

        import resources.StylesLibrary;

        import starling.display.Quad;

        public static const MEDIATOR_NAME:String = "gameScreenBronzeMediator";

        [Bindable]
        private var _mediator:GameScreenMediator;

        override protected function initialize():void
        {
            super.initialize();

            var facade:AppFacade = Facade.getInstance(AppFacade.NAME) as AppFacade;
            if (facade.hasMediator(MEDIATOR_NAME))
            {
                _mediator = facade.retrieveMediator(MEDIATOR_NAME) as GameScreenMediator;
                _mediator.setViewComponent(this);
            }
            else
            {
                _mediator = new GameScreenMediator(MEDIATOR_NAME, this);
                facade.registerMediator(_mediator);
            }
        }

        override public function dispose():void
        {
            if (_mediator)
            {
                var facade:AppFacade = Facade.getInstance(AppFacade.NAME) as AppFacade;
                facade.removeMediator(_mediator.getMediatorName());
            }
            super.dispose();
        }
        ]]></fx:Script>
</f:LayoutGroup>
