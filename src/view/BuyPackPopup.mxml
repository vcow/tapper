<?xml version="1.0"?>
<f:LayoutGroup xmlns:f="library://ns.feathersui.com/mxml" xmlns:fx="http://ns.adobe.com/mxml/2009"
               backgroundSkin="{new Image(atlas.getTexture('details_back'))}"
               maxWidth="414" maxHeight="545">
    <f:layout>
        <f:AnchorLayout/>
    </f:layout>

    <f:Button defaultSkin="{new Image(atlas.getTexture('details_close_bn_normal'))}"
              downSkin="{new Image(atlas.getTexture('details_close_bn_down'))}"
              triggered="{dispatchEventWith(starling.events.Event.CLOSE, false, Const.ON_CANCEL)}">
        <f:layoutData>
            <f:AnchorLayoutData top="15" right="25"/>
        </f:layoutData>
    </f:Button>

    <f:Label text="{title}" styleProvider="{StylesLibrary.woodenShopWidgetLabelStyleProvider}"/>

    <f:Label text="{description}" styleProvider="{StylesLibrary.woodenShopWidgetLabelStyleProvider}"/>

    <f:Button styleProvider="{StylesLibrary.buyPackButtonStyleProvider}" label="{buyBnLabel}"
              triggered="{dispatchEventWith(starling.events.Event.CLOSE, false, Const.ON_OK)}">
        <f:layoutData>
            <f:AnchorLayoutData horizontalCenter="-6" bottom="69"/>
        </f:layoutData>
    </f:Button>

    <fx:Metadata>
        [Event(name="close", type="starling.events.Event")]
    </fx:Metadata>

    <fx:Script><![CDATA[
        import resources.AtlasLibrary;
        import resources.StylesLibrary;

        import starling.display.Image;
        import starling.events.Event;
        import starling.textures.TextureAtlas;

        import vo.Pack;

        private static var _atlas:TextureAtlas;
        private static function get atlas():TextureAtlas
        {
            if (!_atlas)
            {
                _atlas = AtlasLibrary.getInstance().manager.getTextureAtlas("vip");
            }
            return _atlas;
        }

        [Bindable]
        private var title:String;

        [Bindable]
        private var description:String;

        [Bindable]
        private var buyBnLabel:String;

        public function set pack(value:Pack):void
        {
            if (value)
            {
                title = value.title;
                description = value.description;
            }
        }
        ]]></fx:Script>
</f:LayoutGroup>