<?xml version="1.0"?>
<mxml:LayoutGroup xmlns:fx="http://ns.adobe.com/mxml/2009" xmlns:mxml="library://ns.feathersui.com/mxml">
    <mxml:layout>
        <mxml:AnchorLayout/>
    </mxml:layout>

    <mxml:LayoutGroup width="443" height="332" backgroundSkin="{new Quad(10, 10, 0xa0a0a0)}">
        <mxml:layoutData>
            <mxml:AnchorLayoutData horizontalCenter="-5" verticalCenter="-6"/>
        </mxml:layoutData>
    </mxml:LayoutGroup>

    <mxml:LayoutGroup backgroundSkin="{new Image(AtlasLibrary.getInstance().wooden.getTexture('img_border'))}"
                      touchable="false"/>
    <fx:Script><![CDATA[
        import resources.AtlasLibrary;

        import starling.display.Image;
        import starling.display.Quad;
        ]]></fx:Script>
</mxml:LayoutGroup>
