<?xml version="1.0"?>
<view:ShopWidget xmlns:f="library://ns.feathersui.com/mxml" xmlns:fx="http://ns.adobe.com/mxml/2009"
                 xmlns:view="view.*" xmlns:wooden="view.wooden.*">

    <fx:Declarations>
        <wooden:WoodenShopWidgetView id="widgetView" includeInLayout="false" close="hideView()"
                                     complete="{Starling.juggler.removeTweens(widgetView); widgetView.removeFromParent()}"
                                     timeout="2.5"/>
    </fx:Declarations>

    <fx:Script><![CDATA[
        import starling.animation.Transitions;
        import starling.animation.Tween;
        import starling.core.Starling;
        import starling.display.DisplayObject;

        override protected function updateData():void
        {
            Starling.juggler.removeTweens(widgetView);
            widgetView.alpha = 1.0;
            widgetView.scale = 1.0;

            widgetView.text = _data.name;
            showView();
        }

        private function hideView():void
        {
            if (_isActive) {
                _isActive = false;

                const scaleFactor:Number = 0.3;
                const scaleTime:Number = 0.3;
                Starling.juggler.removeTweens(widgetView);
                widgetView.alpha = 1.0;
                var tween:Tween = new Tween(widgetView, scaleTime, Transitions.EASE_OUT);
                tween.animate("x", widgetView.x + ((widgetView.width - widgetView.width * scaleFactor) / 2.0));
                tween.animate("y", widgetView.y + ((widgetView.height - widgetView.height * scaleFactor) / 2.0));
                tween.fadeTo(0.5);
                tween.scaleTo(scaleFactor);
                tween.delay = 0.7;
                Starling.juggler.add(tween);
            }
        }

        public function showView():void
        {
            widgetView.validate();
            widgetView.x = width - widgetView.width;
            widgetView.y = -widgetView.height;

            if (!_isActive) {
                addChild(widgetView);
                _isActive = true;
            }
        }

        override protected function get slider():starling.display.DisplayObject
        {
            return widgetView;
        }

        override public function dispose():void
        {
            widgetView.dispose();
            super.dispose();
        }
        ]]></fx:Script>
</view:ShopWidget>