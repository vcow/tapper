<?xml version="1.0"?>
<f:LayoutGroupListItemRenderer xmlns:f="library://ns.feathersui.com/mxml" xmlns:fx="http://ns.adobe.com/mxml/2009"
               backgroundSkin="{new Quad(20, 20, 0x1a5f7c)}" initialize="{_trigger = new TapToTrigger(this)}">
    <f:layout>
        <f:HorizontalLayout gap="4" padding="5" verticalAlign="middle"/>
    </f:layout>
    <f:layoutData>
        <f:VerticalLayoutData percentWidth="100"/>
    </f:layoutData>

    <f:LayoutGroup backgroundSkin="{new Quad(60, 60, 0x909090)}" touchable="false"/>

    <f:LayoutGroup touchable="false">
        <f:layout>
            <f:VerticalLayout gap="10"/>
        </f:layout>

        <f:Label text="{title}" styleProvider="{StylesLibrary.shopItemTitleLabelStyleProvider}"/>

        <f:Label text="{description}" styleProvider="{StylesLibrary.shopItemTitleLabelStyleProvider}"/>

        <f:Label text="{priceLabel}" styleProvider="{available ? StylesLibrary.availablePriceLabelStyleProvider :
                        StylesLibrary.unavailablePriceLabelStyleProvider}"/>
    </f:LayoutGroup>

    <fx:Script><![CDATA[
        import feathers.utils.touch.TapToTrigger;

        import models.UnitInfo;

        import resources.StylesLibrary;
        import resources.locale.LocaleManager;

        import starling.display.Quad;

        private var _trigger:TapToTrigger;

        [Bindable]
        private var priceLabel:String;

        [Bindable]
        private var description:String;

        [Bindable]
        public var title:String;

        [Bindable]
        public var available:Boolean;

        public function set price(value:Number):void
        {
            priceLabel = isNaN(value) ? LocaleManager.getInstance().getString("common", "na.label") : value.toString();
        }

        override public function set data(value:Object):void
        {
            super.data = value as UnitInfo;
            if (data) {
                title = data.nameWithCounter;

                var locale:LocaleManager = LocaleManager.getInstance();
                var desc:String = "";
                if (data.perClickProfit) {
                    desc += locale.getString("common", "item.ppс.short") + " " +
                            (data.perClickProfit.value.value ?
                            Math.round(data.perClickProfit.value.value).toString() :
                            Math.round(data.perClickProfit.value.percentValue * 100.0) + "%");
                }
                if (data.perSecondProfit) {
                    desc += (desc ? ", " : "") + locale.getString("common", "item.pps.short") + " " +
                            (data.perSecondProfit.value.value ?
                            Math.round(data.perSecondProfit.value.value).toString() :
                            Math.round(data.perSecondProfit.value.percentValue * 100.0) + "%");
                }
                if (data.profit) {
                    desc += (desc ? ", " : "") + "+" + (data.profit.value.value ?
                                    Math.round(data.profit.value.value).toString() :
                            Math.round(data.profit.value.percentValue * 100.0) + "%");
                }
                if (data.action) {
                    desc += (desc ? ", " : "") + data.action.description;
                }
                description = desc;
                price = data.price;
            }
        }
        ]]></fx:Script>
</f:LayoutGroupListItemRenderer>