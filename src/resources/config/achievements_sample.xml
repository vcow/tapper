<?xml version="1.0"?>
<achievements>
	<!-- Ачивка: id - уникальный идентификатор; title - заголовок (optional); description - описание (optional);
	 	isMedal - визуализируется как медаль (optional)
		TODO: добавить визуалку для медалей видимых ачивок -->
	<achievement id="levelup1" isMedal="false" title="Level Up" description="Level Up">
		<!-- Награды ачивки -->
		<rewards>
			<!-- Действие (должно быть поддержано в коде): id - уникальный идентификатор действия;
             title - название действия (optional); description - описание действия (optional) -->
			<action id="levelUp"/>
			<!-- Показать всплывающее окно с сообщением: title - заголовок сообщения; description - текст сообщения.
			 	В заголовке и тексте поддерживаются следующие тэги: %LEVEL% - текущий уровень игрока
			 	TODO: добавить визуалку для сообщения -->
			<popup title="Level Up %LEVEL%" description="Congrats!"/>
			<!-- Профит: value - количество получаемого профита, может быть указано в процентах -->
			<p value="50%"/>
		</rewards>
		<!-- Условия получения ачивки -->
		<conditions>
			<!-- Денег у игрока: min - минимальное количество; max - максимальное количество -->
			<money min="1"/>
			<!-- Количество сделанных кликов: min - минимальное количество; max - маскимальное количество -->
			<taps min="10"/>
			<!-- Количество купленных юнитов: min - минимальное количество; max - максимальное количество.
			 	В качестве дочернего объекта может содержать id юнита, в этом случае учитывается только количество
			 	соответствующих юнитов. Если не указано - учитываются все юниты -->
			<unit min="2">goy</unit>
		</conditions>
	</achievement>
</achievements>